<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="661.0" prefWidth="720.0" style="-fx-background-color: rgba(0,0,0,0.6);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vue.ShopViewController">
    <VBox alignment="TOP_CENTER" spacing="16" styleClass="shop-panel">
        <HBox alignment="CENTER_LEFT">
            <Label styleClass="shop-title" text="🛒  BOUTIQUE" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleClose" styleClass="slot-close-button" text="X" />
        </HBox>
        <Separator />
        <ScrollPane fitToWidth="true" prefHeight="600" styleClass="transparent-scroll">
            <VBox spacing="20">
                <Label styleClass="shop-section-title" text="Schtroumpfs Premium" />
                <VBox fx:id="itemsBox" spacing="14" />
                <Separator />
                <Label styleClass="shop-section-title" text="🎁 Offre Spéciale" />
                <VBox fx:id="bundleBox" spacing="14" />
            </VBox>
        </ScrollPane>
    </VBox>
</StackPane>
